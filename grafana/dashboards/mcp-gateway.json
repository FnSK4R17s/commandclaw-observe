  "panels": [
    {
      "title": "MCP Tool Calls / min",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(mcp_tool_calls_total[1m]) * 60",
          "legendFormat": "{{tool}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "MCP Tool Latency (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(mcp_tool_duration_seconds_bucket[5m]))",
          "legendFormat": "{{tool}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Active MCP Sessions",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "mcp_active_sessions",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Auth Failures / min",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "rate(mcp_auth_failures_total[1m]) * 60",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Key Rotations",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
